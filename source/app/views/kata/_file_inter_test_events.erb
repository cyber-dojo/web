<script>
'use strict';
$(() => {

  const kata = cd.kata;

  // - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  // Inter-Test-Events
  // Called in many places, eg when a file is created, deleted, renamed, 
  // or selected (from the filename-list). Saved inter-test events are 
  // only visible in review mode.

  cd.fileCreateITE = (newFilename, callbacks) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    const args = {
      id: kata.id,
      index: kata.index,
      filename: newFilename,
      data: $('form').serialize()
    };
    syncPostWithCallbackITE('/kata/file_create', args, callbacks);
  };

  cd.fileDeleteITE = (newFilename, callbacks) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    const args = {
      id: kata.id,
      index: kata.index,
      filename: newFilename,
      data: $('form').serialize()
    };
    syncPostWithCallbackITE('/kata/file_delete', args, callbacks);
  };

  cd.fileRenameITE = (oldFilename, newFilename, callbacks) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    const args = {
      id: kata.id,
      index: kata.index,
      old_filename: oldFilename,
      new_filename: newFilename,
      data: $('form').serialize()
    };
    syncPostWithCallbackITE('/kata/file_rename', args, callbacks);
  };

  cd.saveAnyFileChangesITE = (callbacks) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    const args = {
      id: kata.id,
      index: kata.index,
      data: $('form').serialize()
    };
    syncPostWithCallbackITE('/kata/file_edit', args, callbacks);
  };

  const doNothing = () => {};

  const syncPostWithCallbackITE = (url, data, callbacks) => {
    const callback = (name) => {
      return callbacks.hasOwnProperty(name) ? callbacks[name] : doNothing;
    };
    $.ajax({
      timeout: 2*1000,
      type: 'POST',
      url: url,
      data: data
    })
    .success(function(newIndex) {
      kata.setIndex(newIndex);
      callback('success')();
    })
    .error(callback('error'))
    .complete(callback('complete'));
  };

});
</script>
