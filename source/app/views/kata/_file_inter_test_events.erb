<script>
'use strict';
document.addEventListener('DOMContentLoaded', () => {

  const kata = cd.kata;

  // - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  // Inter-Test-Events
  // Called in many places, eg when a file is created, deleted, renamed,
  // or selected (from the filename-list). Saved inter-test events are
  // only visible in review mode.

  cd.fileCreateITE = (newFilename) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    fireAndForgetITE('/kata/file_create', { id: kata.id, filename: newFilename });
  };

  cd.fileDeleteITE = (filename) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    fireAndForgetITE('/kata/file_delete', { id: kata.id, filename: filename });
  };

  cd.fileRenameITE = (oldFilename, newFilename) => {
    cd.saveCodeFromSyntaxHighlightEditors();
    fireAndForgetITE('/kata/file_rename', { id: kata.id, old_filename: oldFilename, new_filename: newFilename });
  };

  cd.saveAnyFileChangesITE = () => {
    cd.saveCodeFromSyntaxHighlightEditors();
    fireAndForgetITE('/kata/file_edit', { id: kata.id });
  };

  const fireAndForgetITE = (url, args) => {
    // Inter-test events are fire-and-forget: dispatch the write and return so the
    // caller can update the UI immediately, never blocking on the response. The
    // browser stamps each event with (tab_id, tab_seq); the spooler forwards to
    // saver in tab_seq order, so a reordered ITE is re-sequenced and a lost one
    // is superseded by the next event's cumulative file set. The body is
    // serialized here, before the caller mutates the editor, so a just-created
    // file is not yet in this event's payload.
    const body = new URLSearchParams(args);
    body.set('data', new URLSearchParams(new FormData(document.querySelector('form'))).toString());
    body.set('tab_id', cd.mobbingPoll.tabId);
    body.set('tab_seq', cd.kata.nextTabSeq());
    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
        'X-Requested-With': 'XMLHttpRequest'
      },
      body
    })
    .catch(() => {});
  };

});
</script>
