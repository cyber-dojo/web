<script>
'use strict';
$(() => {

  // Show the starting-info when a freshly-created kata is opened, ie when the
  // only committed event is the create event (eventCount 1).
  cd.showStartingInfoDialog = (eventCount) => {
    const theDefault = 'on';
    if (eventCount === 1 && cd.lib.setting('starting_info_dialog',theDefault) === 'on') {
      cd.trafficLightsButton().click();
    }
  };

});
</script>
