<button type="button" id="test-button" class="lockable">test</button>

<script>
'use strict';
$(() => {

  const kata = cd.kata;

  const $button = $('#test-button');

  $button.click(() => cd.waitForITE(() => kata.testButton.click()));

  kata.testButton = {
    hide: (f) => {
      disableTestButton();
      $button.hide('slow', f);
    },
    show: () => {
      $button.show('slow', enableTestButton);
    },
    click: () => {
      disableTestButton();
      kata.noPrediction();
      kata.runTests(enableTestButton);
    }
  };

  const  enableTestButton = () => {
    if (cd.kata.isLatest()) {
      $button.attr('disabled', false);
    }
  };
  const disableTestButton = () => $button.attr('disabled', true);

  if (!cd.kata.isLatest()) {
    disableTestButton();
  }

});
</script>
