<button type="button" id="traffic-lights-button" class="info-button">version-control</button>

<dialog id="traffic-lights-dialog" style="width:400px">
  <header>
    <span class="dialog-title">version-control</span>
    <button type="button" class="dialog-close">close</button>
  </header>
  <div class="info">
  <%= partial('shared/traffic_lights_bulb_info') %>
  <%= partial('shared/traffic_lights_click_info') %>
  </div>
  <div class="info">Tests must complete in <span id="max-seconds"></span> seconds</div>
</dialog>

<script>
'use strict';
// Inline (not $()) so document.currentScript is available, letting each partial
// instance wire its own sibling button and dialog without a guard against
// double-initialization when the partial appears twice on the same page.
(function() {
  const dialog = document.currentScript.previousElementSibling;
  const button = dialog.previousElementSibling;
  cd.trafficLightsButton = () => $(button);
  cd.createTip($(button), 'show version-control information');
  dialog.addEventListener('close', () => { if (cd.kata && cd.kata.editor) cd.kata.editor.refocus(); });
  dialog.querySelector('.dialog-close').addEventListener('click', () => dialog.close());
  button.addEventListener('click', () => {
    const manifest = cd.kata.manifest();
    document.getElementById('max-seconds').innerHTML = manifest.max_seconds;
    dialog.showModal();
  });
})();
</script>
