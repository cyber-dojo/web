<button type="button" class="sponsorship">sponsorship</button>

<dialog style="width:440px">
  <header>
    <span class="dialog-title">sponsorship</span>
    <button type="button" class="dialog-close">close</button>
  </header>
  <div class="info">
    Thank you to our sponsors who cover
    all https://cyber-dojo.org hosting costs.
    <br/><br/>
    100% of donations and license fees go to the
    <a href="https://blog.cyber-dojo.org/2015/08/cyber-dojo-foundation.html"
       target="_blank">cyber-dojo Foundation</a> charity.
    <br/><br/>
    If you are interested in being a sponsor
    please email sponsor@cyber-dojo.org
  </div>
</dialog>

<script>
'use strict';
// Inline (not $()) so document.currentScript is available, letting each partial
// instance wire its own sibling button and dialog without a guard against
// double-initialization when the partial appears twice on the same page.
(function() {
  const dialog = document.currentScript.previousElementSibling;
  const button = dialog.previousElementSibling;
  $(dialog).on('close', () => { if (cd.kata && cd.kata.editor) cd.kata.editor.refocus(); });
  $('.dialog-close', dialog).click(() => dialog.close());
  $(button).click(() => dialog.showModal());
})();
</script>
