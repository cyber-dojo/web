<img id="info-button" src="/images/info.png" />

<%= partial('shared/dashboard') %>
<%= partial('shared/feedback') %>
<%= partial('shared/help') %>
<%= partial('shared/hotkeys') %>
<%= partial('shared/micro_services') %>
<%= partial('shared/traffic_lights') %>

<script>
'use strict';
$(() => {

  const $button = $('#info-button');
  const $buttons = () => $('.info-button');
  cd.createTip($button, 'toggle information buttons on/off');
  let visible = false;
  $button[0].addEventListener('click', () => {
    visible = !visible;
    visible ? $buttons().fadeIn() : $buttons().fadeOut();
  });

  $button.click(); // Make visible

});
</script>
