<script>
'use strict';
$(() => {

  const $button = $('#info-button');
  const $buttons = () => $('.info-button');
  cd.createTip($button, 'toggle information buttons on/off');
  $button.clickToggle(() => $buttons().fadeIn(), () => $buttons().fadeOut());

  $button.click(); // Make visible

});
</script>
