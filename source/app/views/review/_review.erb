<%# Included *twice*             %>
<%#  - from review/show.html.erb %>
<%#  - from kata/edit.html.erb   %>

<%= partial('review/index') %>
<%= partial('review/faders') %>
<%= partial('review/lib/avatars') %>
<%= partial('review/lib/get_json') %>
<%= partial('review/lib/pick_file') %>
<%= partial('shared/sorted_filenames') %>

<div class="review-grid">

  <div class="left-column">
    <table class="controls">
      <tr><td><%= partial('review/resume_button') %></td>
          <td><%= partial('review/help_icon') %></td>
          <td><%= partial('review/avatar_navigator') %></td></tr>
          
      <tr><td><%= partial('review/revert_button') %>
              <%= partial('review/checkout_button') %>
              <%= partial('review/fork_button') %></td>
          <td></td>
          <td><%= partial('review/diff_radio_buttons') %>
              </td></tr>                  
    </table>
    <table>
      <tr><td><%= partial('review/filenames') %></td></tr>
      <tr><td><%= partial('review/files') %></td></tr>
      <tr><td><%= partial('review/output') %></td></tr>
    </table>
  </div>

  <div class="right-column">
    <%= partial('review/traffic_light_navigator') %>
    <%= partial('review/traffic_lights') %>
    <div id="diff-content"></div>
    <div id="diff-content-output"></div>
  </div>

  <div class="right-gutter">
    <%= partial('review/traffic_lights_counts') %>
    <%= partial('review/predict_counts') %>
    <%= partial('shared/sponsorship') %>
  </div>

</div>

<script>
'use strict';
$(() => {

  const review = cd.review;

  review.id = undefined;
  review.index = undefined;
  review.events = undefined;

  review.page = $('#review-page'); // Used by _faders and _filenames
  
  review.isFromDashboardPage = () => $('#kata-page').length == 0;
  review.currentEvent = () => review.events[review.index];
  review.lastEvent = () => review.events[review.events.length - 1];
  review.isOnFileEvent = () => cd.lib.isFileEvent(review.currentEvent());

  review.refresh = (id, index) => {
    review.id = id;
    review.index = index;

    review.diffRadio      .refresh();
    review.avatarNavigator.refresh();
    review.files          .refresh();
    review.output         .refresh();
    review.trafficLights  .refresh();
    review.resumeButton   .refresh();
    review.revertButton   .refresh();
    review.checkoutButton .refresh();
    review.forkButton     .refresh();
  };

  const startup = (id, index) => {
    cd.settings.hideButton();
    cd.lib.getEvents(id, (events) => {
      review.events = events;
      review.refresh(id, index == -1 ? events.length-1 : index);
    });
  };

  review.fromTestPage = (id, index) => {
    review.fadeIn(() => {
      startup(id, index);
    });
  };

  if (review.isFromDashboardPage()) {
    review.page.show();
    const index = parseInt(cd.urlParam('now_index', -1));
    startup("<%= @id %>", index);
  }

});
</script>
