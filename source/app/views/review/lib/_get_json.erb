<script>
'use strict';
$(() => {

  const review = cd.review;

  review.getJSON = (url, args, responder) => {
    const params = new URLSearchParams(args);
    cd.waitSpinner.fadeIn('fast', () => {
      fetch(`${url}?${params}`, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(json => {
          cd.waitSpinner.fadeOut('fast', () => responder(json));
        });
    });
  };

});
</script>
