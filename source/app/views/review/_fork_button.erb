<button id="fork-button" type="button">fork</button>

<dialog id="fork-dialog" style="width:270px">
  <header>
    <span class="dialog-title">fork</span>
    <button type="button" class="dialog-close">close</button>
  </header>
  <div class="info">
    create a new practice<br/>
    from this traffic-light's files
  </div>
  <button class="kata"  type="button">ensemble style</button>
  <button class="group" type="button">classroom style</button>
  <button class="kata"  type="button">solo style</button>
</dialog>

<script>
'use strict';
// Inline (not $()) so document.currentScript is available, letting each partial
// instance wire its own sibling button and dialog without a guard against
// double-initialization when the partial appears twice on the same page.
(function() {
  const dialog = document.currentScript.previousElementSibling;
  const button = dialog.previousElementSibling;

  const kata = cd.kata;
  const review = cd.review;

  //- - - - - - - - - - - - - - - - - - - - - - - - -
  // NB: logically there are other possibilities here...
  // - In a classroom practice, you could fork a new avatar (in that group)
  // - A "Deep-Fork" where the new session has the full git
  //   history of the forked-from session.
  // At present, there is no support for either of these.

  const refreshToolTip = () => {
    cd.createTip($(button), () => {
      return `Create a <u>new</u> practice from<br/>${review.nameRagColour()}`;
    });
  };

  review.forkButton = {
    enable: () => $(button).prop('disabled', false),
    disable: () => $(button).prop('disabled', true),
    refresh: () => {
      refreshToolTip();
      if (cd.env['FORK_BUTTON'] == 'off') {
        $(button).hide();
      }
      if (review.isOnFileEvent()) {
        review.forkButton.disable();
      }
      else {
        review.forkButton.enable();
      }
    }
  };

  $('.dialog-close', dialog).click(() => dialog.close());

  //- - - - - - - - - - - - - - - - - - - - - - - - -

  const openForkDialog = () => {
    const rect = button.getBoundingClientRect();
    dialog.style.left = rect.left + 'px';
    dialog.style.top = (rect.top + 30) + 'px';
    dialog.style.margin = '0';
    dialog.showModal();
  };

  const fork = (url, responseKey) => {
    dialog.close();
    const params = new URLSearchParams({ id: review.id, index: review.index });
    fetch(`${url}?${params}`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
        'X-Requested-With': 'XMLHttpRequest',
        'Accept': 'application/json'
      }
    })
    .then(r => r.json())
    .then(response => {
      const id = response[responseKey];
      if (id) {
        window.open(`/creator/enter?id=${id}`);
      } else {
        cd.dialogError(response);
      }
    })
    .catch(err => cd.dialogError(err.toString()));
  };

  //- - - - - - - - - - - - - - - - - - - - - - - - -
  $(button).click(() => openForkDialog());
  $('.kata',  dialog).click(() => fork('/kata/fork',  'kata_fork'));
  $('.group', dialog).click(() => fork('/group/fork', 'group_fork'));

})();
</script>
